  </listRef>
</classSpec><classSpec xmlns:rng="http://relaxng.org/ns/structure/1.0" xmlns:sch="http://purl.oclc.org/dsdl/schematron" xmlns:xi="http://www.w3.org/2001/XInclude" module="tei" type="model" ident="model.emphLike">
  <desc versionDate="2007-10-03" xml:lang="en">groups phrase-level elements which are typographically
