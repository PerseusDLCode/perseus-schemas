</classSpec><classSpec xmlns:rng="http://relaxng.org/ns/structure/1.0" xmlns:sch="http://purl.oclc.org/dsdl/schematron" xmlns:xi="http://www.w3.org/2001/XInclude" module="tei" xml:id="CLDATE" type="model" ident="model.dateLike">
  <desc versionDate="2007-01-31" xml:lang="en">groups elements containing temporal expressions.</desc>
